-- Delta Compatible FPS Booster (Character & Accessory Friendly)

-- 1. Uncap FPS
if setfpscap then
    setfpscap(999)
else
    print("FPS capping not supported by this executor, but optimizations will still apply!")
end

-- 2. Services
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")
local Terrain = Workspace:FindFirstChildOfClass("Terrain")

-- 3. Optimize Terrain
if Terrain then
    Terrain.WaterWaveSize = 0
    Terrain.WaterWaveSpeed = 0
    Terrain.WaterReflectance = 0
    Terrain.WaterTransparency = 0
end

-- 4. Strip Lighting & Shadows
Lighting.GlobalShadows = false
Lighting.FogEnd = 9e9
Lighting.Brightness = 1

-- Remove Screen/Post-Processing Effects
for _, effect in pairs(Lighting:GetChildren()) do
    if effect:IsA("PostEffect") or effect:IsA("BloomEffect") or effect:IsA("BlurEffect") or effect:IsA("SunRaysEffect") or effect:IsA("ColorCorrectionEffect") then
        effect:Destroy()
    end
end

-- 5. Protection Check: Ensures we don't touch Players or their Accessories
local function isPlayerOrAccessory(obj)
    local current = obj
    while current and current ~= Workspace do
        -- Check if it belongs to an Accessory
        if current:IsA("Accessory") or current:IsA("Accoutrement") then
            return true
        end
        -- Check if it belongs to a Player Character Model
        if current:IsA("Model") and Players:GetPlayerFromCharacter(current) then
            return true
        end
        current = current.Parent
    end
    return false
end

-- 6. Material & Texture Stripper Function
local function optimizePart(part)
    -- Skip entirely if this belongs to a player or accessory
    if isPlayerOrAccessory(part) then 
        return 
    end

    if part:IsA("BasePart") and not part:IsA("Terrain") then
        part.Material = Enum.Material.SmoothPlastic
        part.Reflectance = 0
    elseif part:IsA("Decal") or part:IsA("Texture") then
        part:Destroy()
    elseif part:IsA("SpecialMesh") then
        part.TextureId = ""
    end
end

-- Run on existing map geometry
for _, descendant in pairs(Workspace:GetDescendants()) do
    optimizePart(descendant)
end

-- Monitor for map changes (ignoring new player spawns automatically via the check)
Workspace.DescendantAdded:Connect(function(descendant)
    task.wait() -- Brief pause to ensure the object is fully instantiated
    optimizePart(descendant)
end)

print("Player-Safe FPS Booster Loaded Successfully!")
